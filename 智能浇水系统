    <nav class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 flex justify-around items-center h-16 max-w-md mx-auto z-10">
      <button class="nav-btn flex flex-col items-center justify-center text-primary" data-page="device-list-page">
        <i class="fa fa-home text-xl"></i>
        <span class="text-xs mt-1">首页</span>
      </button>
      <button class="nav-btn flex flex-col items-center justify-center text-gray-500" data-page="device-detail-page">
        <i class="fa fa-tachometer text-xl"></i>
        <span class="text-xs mt-1">监测</span>
      </button>
      <button class="nav-btn flex flex-col items-center justify-center text-gray-500" data-page="settings-page">
        <i class="fa fa-cog text-xl"></i>
        <span class="text-xs mt-1">设置</span>
      </button>

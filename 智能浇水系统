  <!-- 设备重命名弹窗 -->
  <div id="rename-modal" class="fixed inset-0 bg-black/50 flex items-center justify-center z-50 hidden">
    <div class="bg-white rounded-xl p-6 w-5/6 max-w-sm">
      <h2 class="text-lg font-semibold text-gray-800 mb-4">重命名设备</h2>
      <input type="text" id="rename-input" class="w-full p-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary mb-4">
      <div class="flex justify-end space-x-3">
        <button id="cancel-rename-btn" class="px-4 py-2 bg-gray-200 text-gray-700 rounded-lg">
          取消
        </button>
        <button id="confirm-rename-btn" class="px-4 py-2 bg-primary text-white rounded-lg">
          确认
        </button>
      </div>
    </div>
  </div>

  <!-- 通知弹窗 -->
  <div id="notification" class="fixed top-4 left-1/2 transform -translate-x-1/2 bg-white rounded-lg shadow-lg p-4 flex items-center space-x-3 z-50 hidden">
    <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-primary">
      <i class="fa fa-check"></i>
    </div>
    <p id="notification-text" class="text-gray-800">水泵已开启</p>
  </div>

  <script>
    // 全局变量
    let currentDeviceId = 'device1';
    let currentPage = 'device-list-page';
    let pumpState = false;
    let irrigationMode = 'manual';
    let autoModeTimer = null;
    let autoModeInterval = 6 * 60 * 60 * 1000; // 自动模式检查间隔，默认6小时
    let irrigationDuration = 30000; // 单次灌溉时长，默认30秒
    let irrigationTimer = null; // 灌溉定时器
    let selectedDevices = ['device1', 'device2']; // 自动模式应用的设备列表，默认选中前两个设备
    let humidityData = {
      device1: [45, 50, 55, 60, 65, 60, 55, 60, 65, 70, 65, 60],
      device2: [30, 35, 32, 30, 28, 32, 35, 30, 28, 32, 35, 32],
      device3: [70, 75, 72, 70, 75, 72, 70, 75, 72, 70, 75, 72]
    };
    let timeLabels = ['8:00', '9:00', '10:00', '11:00', '12:00', '13:00', '14:00', '15:00', '16:00', '17:00', '18:00', '19:00'];
    let humidityGauge = null;
    let humidityChart = null;
    let selectedDevice = null;

    // 设备数据
    const devices = [
      {
        id: 'device1',
        name: '花园',
        status: 'online',
        humidity: 65,
        lastUpdated: '刚刚',
        minHumidity: 30,
        maxHumidity: 80
      },
      {
        id: 'device2',
        name: '蔬菜大棚',
        status: 'online',
        humidity: 32,
        lastUpdated: '2分钟前',
        minHumidity: 40,
        maxHumidity: 70
      },
      {
        id: 'device3',
        name: '室内植物',
        status: 'offline',
        humidity: null,
        lastUpdated: '1小时前',
        minHumidity: 50,
        maxHumidity: 90
      }
    ];

    // DOM 加载完成后执行
    document.addEventListener('DOMContentLoaded', function() {
      // 初始化页面
      initPages();
      
      // 初始化事件监听
      initEventListeners();
      
      // 初始化图表
      initCharts();
      
      // 模拟数据更新
      startDataSimulation();
    });

    // 初始化页面
    function initPages() {
      // 更新设备列表
      updateDeviceList();
      
      // 更新设备详情页
      updateDeviceDetail('device1');
    }

    // 初始化事件监听
    function initEventListeners() {
      // 导航按钮点击事件
      document.querySelectorAll('.nav-btn').forEach(btn => {
        btn.addEventListener('click', function() {
          const page = this.dataset.page;
          navigateTo(page);
        });
      });

      // 设备卡片点击事件
      document.querySelectorAll('.device-card').forEach(card => {
        card.addEventListener('click', function() {
          const deviceId = this.dataset.deviceId;
          updateDeviceDetail(deviceId);
          navigateTo('device-detail-page');
        });
      });

      // 设备卡片长按事件（重命名）
      let pressTimer;
      document.querySelectorAll('.device-card').forEach(card => {
        card.addEventListener('mousedown', function() {
          pressTimer = setTimeout(() => {
            const deviceId = this.dataset.deviceId;
            const device = devices.find(d => d.id === deviceId);
            if (device) {
              showRenameModal(device);
            }
          }, 800);
        });

        card.addEventListener('mouseup', function() {
          clearTimeout(pressTimer);
        });

        card.addEventListener('mouseleave', function() {
          clearTimeout(pressTimer);
        });

        // 触摸事件支持
        card.addEventListener('touchstart', function() {
          pressTimer = setTimeout(() => {
            const deviceId = this.dataset.deviceId;
            const device = devices.find(d => d.id === deviceId);
            if (device) {
              showRenameModal(device);
            }
          }, 800);
        });

        card.addEventListener('touchend', function() {
          clearTimeout(pressTimer);
        });
      });

      // 返回按钮点击事件
      document.getElementById('back-btn').addEventListener('click', function() {
        navigateTo('device-list-page');
      });

      // 设置按钮点击事件
      document.getElementById('settings-btn').addEventListener('click', function() {
        navigateTo('settings-page');
      });

      // 从设置页面返回按钮点击事件
      document.getElementById('back-from-settings-btn').addEventListener('click', function() {
        navigateTo('device-detail-page');
      });

      // 保存设置按钮点击事件
      document.getElementById('save-settings-btn').addEventListener('click', function() {
        saveSettings();
      });

      // 水泵控制按钮点击事件
      document.getElementById('pump-control-btn').addEventListener('click', function() {
        togglePump();
      });
      
      // 快速灌溉滑块事件
      document.getElementById('irrigate-time-slider').addEventListener('input', function() {
        document.getElementById('quick-irrigate-time').textContent = this.value + '秒';
      });
      
      // 阈值滑块事件
      document.getElementById('threshold-slider').addEventListener('input', function() {
        document.getElementById('alert-threshold-value').textContent = this.value + '%';
      });
      
      // 快速操作按钮事件监听
      document.getElementById('quick-irrigate-btn').addEventListener('click', function() {
        quickIrrigate();
      });
      
      document.getElementById('threshold-alert-btn').addEventListener('click', function() {
        setupThresholdAlert();
      });
      
      document.getElementById('device-status-btn').addEventListener('click', function() {
        showDeviceStatus();
      });
      
      document.getElementById('data-analysis-btn').addEventListener('click', function() {
        showDataAnalysis();
      });

      // 时间过滤器按钮点击事件
      document.querySelectorAll('.time-filter').forEach(btn => {
        btn.addEventListener('click', function() {
          const time = this.dataset.time;
          updateChartTimeRange(time);
          
          // 更新按钮样式
          document.querySelectorAll('.time-filter').forEach(b => {
            b.classList.remove('bg-primary', 'text-white');
            b.classList.add('bg-gray-200', 'text-gray-700');
          });
          this.classList.remove('bg-gray-200', 'text-gray-700');
          this.classList.add('bg-primary', 'text-white');
        });
      });

      // 湿度阈值滑块事件
      document.getElementById('min-humidity-slider').addEventListener('input', function() {
        document.getElementById('min-humidity-value').textContent = this.value;
      });

      document.getElementById('max-humidity-slider').addEventListener('input', function() {
        document.getElementById('max-humidity-value').textContent = this.value;
      });
      
      // 自动模式设置事件
      document.getElementById('check-interval-slider').addEventListener('input', function() {
        document.getElementById('check-interval-value').textContent = this.value;
        autoModeInterval = parseFloat(this.value) * 60 * 60 * 1000; // 转换为毫秒
        
        // 如果当前处于自动模式，重新启动定时器
        if (irrigationMode === 'auto') {
          startAutoMode();
        }
      });
      
      document.getElementById('irrigation-duration-slider').addEventListener('input', function() {
        document.getElementById('irrigation-duration-value').textContent = this.value;
        irrigationDuration = parseInt(this.value) * 1000;
      });
      
      // 全选/取消全选事件
      document.getElementById('select-all-devices').addEventListener('change', function() {
        const isChecked = this.checked;
        document.querySelectorAll('.device-checkbox').forEach(checkbox => {
          checkbox.checked = isChecked;
        });
        updateSelectedDevices();
      });
      
      // 单个设备选择事件
      document.querySelectorAll('.device-checkbox').forEach(checkbox => {
        checkbox.addEventListener('change', function() {
          updateSelectedDevices();
          
          // 更新"所有设备"复选框状态
          const allCheckboxes = document.querySelectorAll('.device-checkbox');
          const allChecked = Array.from(allCheckboxes).every(cb => cb.checked);
          const noneChecked = Array.from(allCheckboxes).every(cb => !cb.checked);
          
          const selectAllCheckbox = document.getElementById('select-all-devices');
          selectAllCheckbox.checked = allChecked;
          selectAllCheckbox.indeterminate = !allChecked && !noneChecked;
        });
      });
      
      // 更新选中设备列表
      function updateSelectedDevices() {
        selectedDevices = [];
        document.querySelectorAll('.device-checkbox:checked').forEach(checkbox => {
          selectedDevices.push(checkbox.value);
        });
        
        console.log('自动模式设备已更新，选中的设备：', selectedDevices.map(id => devices.find(d => d.id === id)?.name).join(', '));
        
        // 如果当前处于自动模式，重新启动定时器
        if (irrigationMode === 'auto') {
          startAutoMode();
          showNotification('自动模式设备已更新');
        }
      }

      // 定时开关切换事件
      document.getElementById('timer-toggle').addEventListener('change', function() {
        const timerSettings = document.getElementById('timer-settings');
        if (this.checked) {
          timerSettings.classList.remove('hidden');
        } else {
          timerSettings.classList.add('hidden');
        }
      });

      // 星期选择按钮点击事件
      document.querySelectorAll('.day-btn').forEach(btn => {
        btn.addEventListener('click', function() {
          this.classList.toggle('bg-primary');
          this.classList.toggle('text-white');
          this.classList.toggle('bg-gray-200');
          this.classList.toggle('text-gray-700');
        });
      });

      // 添加设备按钮点击事件
      document.getElementById('add-device-btn').addEventListener('click', function() {
        navigateTo('add-device-page');
      });

      // 从添加设备页面返回按钮点击事件
      document.getElementById('back-from-add-device-btn').addEventListener('click', function() {
        navigateTo('device-list-page');
      });

      // 扫描设备按钮点击事件
      document.getElementById('scan-device-btn').addEventListener('click', function() {
        scanDevices();
      });

      // 连接设备按钮点击事件
      document.querySelectorAll('.connect-device-btn').forEach(btn => {
        btn.addEventListener('click', function() {
          const deviceName = this.closest('div').querySelector('h3').textContent;
          connectDevice(deviceName);
        });
      });

      // 重命名弹窗取消按钮点击事件
      document.getElementById('cancel-rename-btn').addEventListener('click', function() {
        hideRenameModal();
      });

      // 重命名弹窗确认按钮点击事件
      document.getElementById('confirm-rename-btn').addEventListener('click', function() {
        confirmRename();
      });
    }

    // 初始化图表
    function initCharts() {
      // 初始化湿度趋势图表
      const chartCtx = document.getElementById('humidity-chart').getContext('2d');
      humidityChart = new Chart(chartCtx, {
        type: 'line',
        data: {
          labels: timeLabels,
          datasets: [{
            label: '土壤湿度 (%)',
            data: humidityData.device1,
            borderColor: '#22c55e',
            backgroundColor: 'rgba(34, 197, 94, 0.1)',
            borderWidth: 2,
            fill: true,
            tension: 0.4,
            pointBackgroundColor: '#22c55e',
            pointRadius: 4,
            pointHoverRadius: 6
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              display: false
            },
            tooltip: {
              mode: 'index',
              intersect: false,
              backgroundColor: 'rgba(255, 255, 255, 0.9)',
              titleColor: '#1f2937',
              bodyColor: '#4b5563',
              borderColor: '#e5e7eb',
              borderWidth: 1,
              padding: 10,
              boxPadding: 5,
              usePointStyle: true,
              callbacks: {
                label: function(context) {
                  return `湿度: ${context.parsed.y}%`;
                }
              }
            }
          },
          scales: {
            x: {
              grid: {
                display: false
              },
              ticks: {
                color: '#9ca3af'
              }
            },
            y: {
              beginAtZero: true,
              max: 100,
              grid: {
                color: '#f3f4f6'
              },
              ticks: {
                color: '#9ca3af'
              }
            }
          }
        }
      });
    }

    // 页面导航
    function navigateTo(pageId) {
      // 隐藏所有页面
      document.querySelectorAll('.page').forEach(page => {
        page.classList.add('hidden');
      });
      
      // 显示目标页面
      document.getElementById(pageId).classList.remove('hidden');
      
      // 更新当前页面
      currentPage = pageId;
      
      // 更新底部导航栏状态
      document.querySelectorAll('.nav-btn').forEach(btn => {
        if (btn.dataset.page === pageId) {
          btn.classList.remove('text-gray-500');
          btn.classList.add('text-primary');
        } else {
          btn.classList.remove('text-primary');
          btn.classList.add('text-gray-500');
        }
      });
    }

    // 更新设备列表
    function updateDeviceList() {
      const deviceList = document.getElementById('device-list');
      deviceList.innerHTML = '';
      
      devices.forEach(device => {
        const deviceCard = document.createElement('div');
        deviceCard.className = `device-card bg-white rounded-xl p-4 card-shadow border-l-4 ${device.status === 'online' ? (device.humidity < device.minHumidity ? 'border-warning' : 'border-primary') : 'border-gray-400'}`;
        deviceCard.dataset.deviceId = device.id;
        
        deviceCard.innerHTML = `
          <div class="flex justify-between items-start">
            <div>
              <div class="flex items-center">
                <h3 class="text-lg font-semibold text-gray-800 device-name">${device.name}</h3>
                <span class="ml-2 px-2 py-1 ${device.status === 'online' ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800'} text-xs rounded-full">${device.status === 'online' ? '在线' : '离线'}</span>
              </div>
              <p class="text-gray-500 text-sm mt-1">最后更新: ${device.lastUpdated}</p>
            </div>
            <div class="text-right">
              <p class="text-2xl font-bold ${device.status === 'online' ? (device.humidity < device.minHumidity ? 'text-warning' : 'text-primary') : 'text-gray-400'} device-humidity">${device.humidity !== null ? device.humidity + '%' : '--'}</p>
              <p class="text-xs text-gray-500">土壤湿度</p>
            </div>
          </div>
          <div class="mt-3">
            <div class="w-full bg-gray-200 rounded-full h-2.5">
              <div class="bg-${device.status === 'online' ? (device.humidity < device.minHumidity ? 'warning' : 'primary') : 'gray-400'} h-2.5 rounded-full device-humidity-bar" style="width: ${device.humidity !== null ? device.humidity : 0}%"></div>
            </div>
          </div>
        `;
        
        // 添加点击事件
        deviceCard.addEventListener('click', function() {
          const deviceId = this.dataset.deviceId;
          updateDeviceDetail(deviceId);
          navigateTo('device-detail-page');
        });
        
        // 添加长按事件（重命名）
        let pressTimer;
        deviceCard.addEventListener('mousedown', function() {
          pressTimer = setTimeout(() => {
            const deviceId = this.dataset.deviceId;
            const device = devices.find(d => d.id === deviceId);
            if (device) {
              showRenameModal(device);
            }
          }, 800);
        });

        deviceCard.addEventListener('mouseup', function() {
          clearTimeout(pressTimer);
        });

        deviceCard.addEventListener('mouseleave', function() {
          clearTimeout(pressTimer);
        });

        // 触摸事件支持
        deviceCard.addEventListener('touchstart', function() {
          pressTimer = setTimeout(() => {
            const deviceId = this.dataset.deviceId;
            const device = devices.find(d => d.id === deviceId);
            if (device) {
              showRenameModal(device);
            }
          }, 800);
        });

        deviceCard.addEventListener('touchend', function() {
          clearTimeout(pressTimer);
        });
        
        deviceList.appendChild(deviceCard);
      });
      
      // 更新自动模式设备选择列表
      updateAutoModeDeviceList();
    }

    // 快速灌溉功能
    function quickIrrigate() {
      if (pumpState) {
        showNotification('水泵已在运行中');
        return;
      }
      
      const duration = parseInt(document.getElementById('irrigate-time-slider').value);
      
      // 开启水泵
      togglePump();
      showNotification(`快速灌溉已启动，持续${duration}秒`);
      
      // 设定时间后自动关闭
      setTimeout(() => {
        if (pumpState) {
          togglePump();
          showNotification('快速灌溉已完成');
        }
      }, duration * 1000);
    }
    
    // 阈值提醒设置
    function setupThresholdAlert() {
      const device = devices.find(d => d.id === currentDeviceId);
      if (!device) return;
      
      const threshold = parseInt(document.getElementById('threshold-slider').value);
      
      // 更新设备阈值
      device.minHumidity = threshold;
      
      // 更新设置页面的阈值显示
      document.getElementById('min-humidity-slider').value = threshold;
      document.getElementById('min-humidity-value').textContent = threshold;
      
      showNotification(`阈值提醒已设置：低于${threshold}%时将提醒`);
    }
    
    // 显示设备状态
    function showDeviceStatus() {
      const device = devices.find(d => d.id === currentDeviceId);
      if (!device) return;
      
      const statusText = device.status === 'online' ? '在线' : '离线';
      const statusColor = device.status === 'online' ? 'text-green-600' : 'text-gray-600';
      
      document.getElementById('current-status').textContent = statusText;
      document.getElementById('current-status').className = `text-xs ${statusColor}`;
      
      showNotification(`设备状态：${statusText}`);
    }
    
    // 显示数据分析
    function showDataAnalysis() {
      showNotification('正在生成数据分析报告...');
      
      // 模拟加载延迟
      setTimeout(() => {
        // 这里可以添加更复杂的数据分析逻辑
        const device = devices.find(d => d.id === currentDeviceId);
        if (device) {
          const avgHumidity = Math.round(device.humidity);
          const status = device.humidity < device.minHumidity ? '干燥' : 
                        device.humidity > device.maxHumidity ? '湿润' : '适中';
          
          showNotification(`分析报告：平均湿度${avgHumidity}%，当前状态：${status}`);
        }
      }, 1500);
    }

    // 更新设备详情页
    function updateDeviceDetail(deviceId) {
      const device = devices.find(d => d.id === deviceId);
      if (!device) return;
      
      currentDeviceId = deviceId;
      
      // 更新页面标题
      document.querySelector('#device-detail-page .device-title').textContent = device.name;
      
      // 更新当前湿度
      const humidityText = device.humidity !== null ? device.humidity + '%' : '--';
      document.getElementById('current-humidity-text').textContent = humidityText;
      
      // 更新湿度进度条
      const humidityProgress = document.getElementById('humidity-progress');
      if (device.humidity !== null) {
        humidityProgress.style.width = device.humidity + '%';
        humidityProgress.className = `h-3 rounded-full transition-all duration-500 ease-out ${
          device.humidity < device.minHumidity ? 'bg-warning' : 
          device.humidity > device.maxHumidity ? 'bg-danger' : 'bg-primary'
        }`;
      } else {
        humidityProgress.style.width = '0%';
        humidityProgress.className = 'h-3 rounded-full transition-all duration-500 ease-out bg-gray-400';
      }
      
      // 湿度仪表盘已移除，无需更新
      
      // 更新湿度趋势图表
      if (humidityChart && humidityData[deviceId]) {
        humidityChart.data.datasets[0].data = humidityData[deviceId];
        humidityChart.update();
      }
      
      // 更新快速操作面板
      document.getElementById('threshold-slider').value = device.minHumidity;
      document.getElementById('alert-threshold-value').textContent = device.minHumidity + '%';
      
      const statusText = device.status === 'online' ? '在线' : '离线';
      const statusColor = device.status === 'online' ? 'text-green-600' : 'text-gray-600';
      document.getElementById('current-status').textContent = statusText;
      document.getElementById('current-status').className = `text-xs ${statusColor}`;
      
      // 更新设置页面
      document.getElementById('device-name-input').value = device.name;
      document.getElementById('min-humidity-slider').value = device.minHumidity;
      document.getElementById('min-humidity-value').textContent = device.minHumidity;
      document.getElementById('max-humidity-slider').value = device.maxHumidity;
      document.getElementById('max-humidity-value').textContent = device.maxHumidity;
    }

    // 切换水泵状态
    function togglePump() {
      pumpState = !pumpState;
      const pumpBtn = document.getElementById('pump-control-btn');
      const pumpStatus = document.getElementById('pump-status');
      
      if (pumpState) {
        pumpBtn.classList.remove('bg-primary');
        pumpBtn.classList.add('bg-danger');
        pumpStatus.textContent = '关闭';
      } else {
        pumpBtn.classList.remove('bg-danger');
        pumpBtn.classList.add('bg-primary');
        pumpStatus.textContent = '开启';
      }
      
      // 模拟WebSocket发送控制指令
      console.log(`发送水泵控制指令: ${pumpState ? '开启' : '关闭'}`);
    }

    // 设置灌溉模式
    function setIrrigationMode(mode) {
      irrigationMode = mode;
      
      if (mode === 'manual') {
        // 切换到手动模式
        // 停止自动模式定时器
        stopAutoMode();
        
        showNotification('已切换到手动模式');
      } else {
        // 切换到自动模式
        // 启动自动模式
        startAutoMode();
        
        showNotification('已切换到自动模式');
      }
    }
    
    // 启动自动模式
    function startAutoMode() {
      // 清除可能存在的定时器
      stopAutoMode();
      
      // 立即执行一次检查
      checkAutoIrrigation();
      
      // 设置定时器，定期检查土壤湿度
      autoModeTimer = setInterval(checkAutoIrrigation, autoModeInterval);
      
      console.log('自动模式已启动，检查间隔：' + (autoModeInterval / 1000) + '秒');
    }
    
    // 停止自动模式
    function stopAutoMode() {
      if (autoModeTimer) {
        clearInterval(autoModeTimer);
        autoModeTimer = null;
        console.log('自动模式已停止');
      }
    }
    
    // 自动灌溉检查
    function checkAutoIrrigation() {
      // 如果没有选中任何设备，直接返回
      if (selectedDevices.length === 0) {
        console.log('自动模式：未选中任何设备，跳过检查');
        return;
      }
      
      // 获取所有需要检查的设备
      const devicesToCheck = devices.filter(device => 
        selectedDevices.includes(device.id) && 
        device.status === 'online' && 
        device.humidity !== null
      );
      
      console.log(`自动模式：开始检查${devicesToCheck.length}个设备的土壤湿度`);
      
      // 遍历所有需要检查的设备
      devicesToCheck.forEach(device => {
        console.log(`自动检查设备[${device.name}]土壤湿度：${device.humidity}%，最小值：${device.minHumidity}%，最大值：${device.maxHumidity}%`);
        
        // 根据湿度阈值控制水泵
        if (device.humidity < device.minHumidity && !pumpState) {
          // 湿度过低，开启水泵
          togglePump();
          showNotification(`自动模式：设备[${device.name}]土壤湿度低于阈值(${device.minHumidity}%)，已开启水泵`);
          
          // 设置定时器，达到灌溉时长后自动关闭水泵
          if (irrigationTimer) {
            clearTimeout(irrigationTimer);
          }
          
          irrigationTimer = setTimeout(() => {
            if (pumpState) {
              togglePump();
              showNotification('自动模式：灌溉时长已到，已关闭水泵');
            }
          }, irrigationDuration);
        } else if (device.humidity > device.maxHumidity && pumpState) {
          // 湿度过高，关闭水泵
          togglePump();
          showNotification(`自动模式：设备[${device.name}]土壤湿度高于阈值(${device.maxHumidity}%)，已关闭水泵`);
          
          // 清除灌溉定时器
          if (irrigationTimer) {
            clearTimeout(irrigationTimer);
            irrigationTimer = null;
          }
        }
      });
    }

    // 更新图表时间范围
    function updateChartTimeRange(time) {
      let labels = [];
      let data = [];
      
      switch (time) {
        case 'day':
          labels = timeLabels;
          data = humidityData[currentDeviceId];
          break;
        case 'week':
          labels = ['周一', '周二', '周三', '周四', '周五', '周六', '周日'];
          data = [55, 60, 65, 60, 55, 60, 65];
          break;
        case 'month':
          labels = ['第1周', '第2周', '第3周', '第4周'];
          data = [60, 65, 60, 65];
          break;
      }
      
      humidityChart.data.labels = labels;
      humidityChart.data.datasets[0].data = data;
      humidityChart.update();
    }

    // 保存设置
    function saveSettings() {
      const device = devices.find(d => d.id === currentDeviceId);
      if (!device) return;
      
      // 更新设备名称
      const newName = document.getElementById('device-name-input').value.trim();
      if (newName) {
        device.name = newName;
      }
      
      // 更新湿度阈值
      device.minHumidity = parseInt(document.getElementById('min-humidity-slider').value);
      device.maxHumidity = parseInt(document.getElementById('max-humidity-slider').value);
      
      // 更新设备详情页
      updateDeviceDetail(currentDeviceId);
      
      // 更新设备列表
      updateDeviceList();
      
      // 显示通知
      showNotification('设置已保存');
      
      // 返回设备详情页
      navigateTo('device-detail-page');
    }

    // 扫描设备
    function scanDevices() {
      const scanBtn = document.getElementById('scan-device-btn');
      scanBtn.classList.add('animate-spin');
      
      // 模拟扫描过程
      setTimeout(() => {
        scanBtn.classList.remove('animate-spin');
        showNotification('扫描完成');
      }, 2000);
    }

    // 连接设备
    function connectDevice(deviceName) {
      // 模拟连接过程
      showNotification(`正在连接 ${deviceName}...`);
      
      setTimeout(() => {
        // 创建新设备
        const newDevice = {
          id: 'device' + (devices.length + 1),
          name: deviceName,
          status: 'online',
          humidity: Math.floor(Math.random() * 50) + 30,
          lastUpdated: '刚刚',
          minHumidity: 30,
          maxHumidity: 80
        };
        
        // 添加到设备列表
        devices.push(newDevice);
        
        // 生成随机湿度数据
        humidityData[newDevice.id] = Array.from({length: 12}, () => Math.floor(Math.random() * 50) + 30);
        
        // 更新设备列表
        updateDeviceList();
        
        // 更新自动模式设备选择列表
        updateAutoModeDeviceList();
        
        // 显示通知
        showNotification(`设备 ${deviceName} 连接成功`);
        
        // 返回设备列表页
        navigateTo('device-list-page');
      }, 2000);
    }

    // 显示重命名弹窗
    function showRenameModal(device) {
      selectedDevice = device;
      document.getElementById('rename-input').value = device.name;
      document.getElementById('rename-modal').classList.remove('hidden');
    }

    // 隐藏重命名弹窗
    function hideRenameModal() {
      selectedDevice = null;
      document.getElementById('rename-modal').classList.add('hidden');
    }

    // 确认重命名
    function confirmRename() {
      if (!selectedDevice) return;
      
      const newName = document.getElementById('rename-input').value.trim();
      if (newName) {
        selectedDevice.name = newName;
        
        // 更新设备列表
        updateDeviceList();
        
        // 如果当前在设备详情页，更新页面标题
        if (currentPage === 'device-detail-page' && selectedDevice.id === currentDeviceId) {
          document.querySelector('#device-detail-page .device-title').textContent = newName;
        }
        
        // 显示通知
        showNotification('设备名称已更新');
      }
      
      // 隐藏弹窗
      hideRenameModal();
    }

    // 更新自动模式设备选择列表
    function updateAutoModeDeviceList() {
      const deviceCheckboxesContainer = document.querySelector('#settings-page .grid.grid-cols-2.gap-2.mt-2');
      if (!deviceCheckboxesContainer) return;
      
      // 清空现有设备选择
      deviceCheckboxesContainer.innerHTML = '';
      
      // 添加所有设备的复选框
      devices.forEach(device => {
        const checkboxDiv = document.createElement('div');
        checkboxDiv.className = 'flex items-center';
        
        const isChecked = selectedDevices.includes(device.id);
        
        checkboxDiv.innerHTML = `
          <input type="checkbox" id="select-${device.id}" class="device-checkbox w-4 h-4 text-primary bg-gray-100 border-gray-300 rounded focus:ring-primary" value="${device.id}" ${isChecked ? 'checked' : ''}>
          <label for="select-${device.id}" class="ml-2 text-sm font-medium text-gray-700">${device.name}</label>
        `;
        
        deviceCheckboxesContainer.appendChild(checkboxDiv);
      });
      
      // 重新添加事件监听器
      document.querySelectorAll('.device-checkbox').forEach(checkbox => {
        checkbox.addEventListener('change', function() {
          updateSelectedDevices();
          
          // 更新"所有设备"复选框状态
          const allCheckboxes = document.querySelectorAll('.device-checkbox');
          const allChecked = Array.from(allCheckboxes).every(cb => cb.checked);
          const noneChecked = Array.from(allCheckboxes).every(cb => !cb.checked);
          
          const selectAllCheckbox = document.getElementById('select-all-devices');
          selectAllCheckbox.checked = allChecked;
          selectAllCheckbox.indeterminate = !allChecked && !noneChecked;
        });
      });
      
      // 更新"所有设备"复选框状态
      const allCheckboxes = document.querySelectorAll('.device-checkbox');
      const allChecked = Array.from(allCheckboxes).every(cb => cb.checked);
      const noneChecked = Array.from(allCheckboxes).every(cb => !cb.checked);
      
      const selectAllCheckbox = document.getElementById('select-all-devices');
      selectAllCheckbox.checked = allChecked;
      selectAllCheckbox.indeterminate = !allChecked && !noneChecked;
    }

    // 显示通知
    function showNotification(message) {
      const notification = document.getElementById('notification');
      document.getElementById('notification-text').textContent = message;
      
      notification.classList.remove('hidden');
      
      setTimeout(() => {
        notification.classList.add('hidden');
      }, 3000);
    }

    // 模拟数据更新
    function startDataSimulation() {
      setInterval(() => {
        devices.forEach(device => {
          if (device.status === 'online') {
            // 随机波动湿度值
            const variation = Math.floor(Math.random() * 5) - 2; // -2 到 2 之间的随机数
            device.humidity = Math.max(0, Math.min(100, device.humidity + variation));
            device.lastUpdated = '刚刚';
            
            // 更新湿度数据数组
            if (humidityData[device.id]) {
              humidityData[device.id].push(device.humidity);
              humidityData[device.id].shift();
            }
            
            // 如果当前在查看该设备的详情页，更新图表
            if (currentPage === 'device-detail-page' && device.id === currentDeviceId) {
              updateDeviceDetail(device.id);
              
              // 如果处于自动模式，检查是否需要灌溉
              if (irrigationMode === 'auto') {
                checkAutoIrrigation();
              }
            }
          }
        });
        
        // 更新设备列表
        updateDeviceList();
      }, 5000);
    }
  </script>

</body></html>

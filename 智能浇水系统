          <div class="bg-white rounded-xl p-4 card-shadow">
            <h2 class="text-lg font-semibold text-gray-800 mb-4">手动添加</h2>
            <div class="space-y-4">
              <div>
                <label class="block text-gray-700 text-sm font-medium mb-2">
                  设备IP地址
                </label>
                <input type="text" class="w-full p-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary" placeholder="192.168.1.x">
              </div>
              <div>
                <label class="block text-gray-700 text-sm font-medium mb-2">
                  设备名称
                </label>
                <input type="text" class="w-full p-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary" placeholder="例如：阳台植物">

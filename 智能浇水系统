              <div class="flex justify-between items-center p-3 bg-gray-100 rounded-lg">
                <div>
                  <h3 class="font-medium text-gray-800">ESP32-Soil-Monitor-2</h3>
                  <p class="text-xs text-gray-500">192.168.1.101</p>
                </div>
                <button class="connect-device-btn px-4 py-2 bg-primary text-white rounded-lg text-sm">
                  连接
                </button>
              </div>
            </div>
